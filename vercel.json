{
  "version": 2,
  "builds": [
    {
      "src": "project/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10",
        "maxLambdaSize": "15mb",
        "buildCommand": "pip install --no-cache-dir -r project/requirements.txt"
      }
    },
    {
      "src": "project/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "project/frontend/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "project/main.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "project/frontend/build/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": ".",
    "POETRY_VIRTUALENVS_CREATE": "false",
    "PIP_NO_BINARY": "aiohttp"
  }
} 
